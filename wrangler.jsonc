{
	"name": "glyphin-alpha",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_date": "2026-07-12",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare",
	},
	"ratelimits": [
		{
			"name": "LEARNER_SYNC_RATE_LIMITER",
			"namespace_id": "2026071201",
			"simple": {
				"limit": 12,
				"period": 60,
			},
		},
	],
}
