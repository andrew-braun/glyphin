{
	"name": "glyphin",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"prebuild": "pnpm publication:generate",
		"preview": "vite preview",
		"db:seed:refresh": "node scripts/write-thai-seed.mjs",
		"db:start": "supabase start",
		"db:stop": "supabase stop",
		"db:content:refresh": "node scripts/refresh-local-content.mjs",
		"db:reset": "pnpm db:seed:refresh && supabase db reset --yes && supabase start && pnpm publication:generate",
		"db:lint": "supabase db lint",
		"db:smoke:delivery": "node scripts/smoke-delivery-payload.mjs",
		"db:prod:login": "supabase login",
		"db:prod:projects": "supabase projects list",
		"db:prod:link": "supabase link",
		"db:prod:lint": "supabase db lint --linked",
		"db:prod:advisors": "supabase db advisors --linked",
		"db:prod:push:dry-run": "supabase db push --dry-run",
		"db:prod:push": "supabase db push",
		"db:prod:reset:fresh-alpha": "supabase db reset --linked",
		"curriculum:scaffold": "node scripts/curriculum-authoring-tools.mjs scaffold",
		"curriculum:validate": "node scripts/curriculum-authoring-tools.mjs validate",
		"curriculum:score": "node scripts/curriculum-authoring-tools.mjs score",
		"curriculum:review": "node scripts/curriculum-authoring-tools.mjs review",
		"publication:generate": "node scripts/generate-publication-artifact.mjs",
		"prepare": "husky && svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . --cache --cache-location .eslintcache",
		"lint:fix": "eslint . --fix --cache --cache-location .eslintcache",
		"lint:staged": "lint-staged",
		"markdownlint": "markdownlint-cli2 --config .markdownlint.jsonc \"**/*.md\" \"#node_modules\" \"#build\" \"#.svelte-kit\"",
		"markdownlint:fix": "markdownlint-cli2 --config .markdownlint.jsonc --fix \"**/*.md\" \"#node_modules\" \"#build\" \"#.svelte-kit\"",
		"knip": "knip",
		"stylelint": "stylelint \"src/**/*.{css,scss,svelte}\" --cache --cache-location .stylelintcache",
		"stylelint:fix": "stylelint \"src/**/*.{css,scss,svelte}\" --config ./stylelint.sort.config.mjs --fix --cache --cache-location .stylelintcache",
		"check:all": "pnpm quality:check",
		"quality:check": "pnpm format:check && pnpm markdownlint && pnpm lint && pnpm stylelint && pnpm check",
		"quality:fix": "pnpm format && pnpm markdownlint:fix && pnpm lint:fix && pnpm stylelint:fix && pnpm check",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"engines": {
		"node": "24.15.0",
		"pnpm": "^11"
	},
	"packageManager": "pnpm@11.8.0",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.8.0",
			"onFail": "download"
		}
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260711.1",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/node": "^24.13.3",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"eslint-plugin-svelte": "^3.20.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"knip": "^6.25.0",
		"lint-staged": "^17.0.8",
		"markdownlint-cli2": "^0.23.0",
		"postcss-html": "^1.8.1",
		"postcss-scss": "^4.0.9",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"stylelint": "^17.14.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-recommended-scss": "^17.0.1",
		"stylelint-order": "^8.1.1",
		"supabase": "^2.106.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4",
		"wrangler": "^4.110.0"
	},
	"lint-staged": {
		"*.{js,cjs,mjs,ts,cts,mts}": [
			"eslint --fix --cache --cache-location .eslintcache",
			"prettier --write"
		],
		"*.svelte": [
			"eslint --fix --cache --cache-location .eslintcache",
			"stylelint --config ./stylelint.sort.config.mjs --fix --cache --cache-location .stylelintcache",
			"prettier --write"
		],
		"*.{css,scss}": [
			"stylelint --config ./stylelint.sort.config.mjs --fix --cache --cache-location .stylelintcache",
			"prettier --write"
		],
		"*.md": [
			"prettier --write",
			"markdownlint-cli2 --config .markdownlint.jsonc --fix"
		],
		"*.{json,jsonc,yml,yaml}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@lucide/svelte": "^1.24.0",
		"@supabase/ssr": "^0.12.0",
		"@supabase/supabase-js": "^2.108.1",
		"bits-ui": "^2.18.1",
		"sass": "^1.101.0"
	},
	"volta": {
		"node": "24.15.0"
	}
}
