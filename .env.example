# Server-side delivery reads (private — never exposed to the browser)
# Local dev: run `pnpm exec supabase status -o env`, then map
# API_URL        -> SUPABASE_DELIVERY_URL
# PUBLISHABLE_KEY -> SUPABASE_DELIVERY_ANON_KEY
# (The anon key is public by nature but kept in a private var here to maintain a
#  clean server/client boundary. If a service-role key is ever needed for delivery
#  reads, only this variable changes — no public bundle risk.)
SUPABASE_DELIVERY_URL=
SUPABASE_DELIVERY_ANON_KEY=

# Server-side Supabase Auth (private — never exposed to the browser)
# Local dev: map API_URL -> SUPABASE_AUTH_URL and PUBLISHABLE_KEY -> SUPABASE_AUTH_PUBLISHABLE_KEY.
# The publishable key is public by nature, but Glyphin keeps it server-only so the browser
# never creates a Supabase client or sends Supabase database queries directly.
SUPABASE_AUTH_URL=
SUPABASE_AUTH_PUBLISHABLE_KEY=

# Public canonical origin used only for absolute SEO URLs (for example, https://example.com).
# Set this to the production https:// origin with no path, query string, or fragment.
PUBLIC_SITE_ORIGIN=
